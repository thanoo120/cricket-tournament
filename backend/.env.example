# ============================================================
# Cricket Tournament — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values for your environment.
# In production, set these as real OS / container environment variables
# (do NOT commit a filled-in .env to version control).
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8080

# ── Database ─────────────────────────────────────────────────
# Development default: H2 in-memory (no setup needed).
# For production, uncomment and fill the MySQL block below.

# H2 (default — leave these unset to use the built-in defaults)
# DB_URL=jdbc:h2:mem:cricketdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE;NON_KEYWORDS=YEAR
# DB_DRIVER=org.h2.Driver
# DB_USERNAME=sa
# DB_PASSWORD=
# JPA_DIALECT=org.hibernate.dialect.H2Dialect
# H2_CONSOLE=true

# MySQL (production)
# DB_URL=jdbc:mysql://localhost:3306/cricket_tournament?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password
# JPA_DIALECT=org.hibernate.dialect.MySQLDialect
# DDL_AUTO=validate
# H2_CONSOLE=false

# ── JPA / Hibernate ──────────────────────────────────────────
# Options: create | create-drop | update | validate | none
# Use "validate" in production (schema managed by migrations).
DDL_AUTO=update

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example for production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: replace with a long random secret (min 32 characters).
# Generate one with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-in-production-min-32-chars

# Token expiry in milliseconds. Default: 86400000 (24 hours).
JWT_EXPIRATION_MS=86400000

# ── Auth Credentials ─────────────────────────────────────────
# Change these in production. These are the login credentials for the web app.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cricket@2025
ADMIN_NAME=Administrator

SCORER_USERNAME=scorer
SCORER_PASSWORD=scorer@2025
SCORER_NAME=Match Scorer

# ── Spring Profile ───────────────────────────────────────────
# "dev"  — enables H2 console + sample data seeding (DataInitializer runs)
# "prod" — disables sample data seeding; use with a real database
SPRING_PROFILES_ACTIVE=dev
