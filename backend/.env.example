# ============================================================
# Cricket Tournament — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# In production set these as real OS / container env vars —
# do NOT commit a filled-in .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8080

# ── Database ─────────────────────────────────────────────────
# Default (dev): H2 in-memory — no setup needed.
# For production, set the MySQL block below.

# H2 — leave unset to use built-in defaults
# DB_URL=jdbc:h2:mem:cricketdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE;NON_KEYWORDS=YEAR
# DB_DRIVER=org.h2.Driver
# DB_USERNAME=sa
# DB_PASSWORD=
# JPA_DIALECT=org.hibernate.dialect.H2Dialect
# H2_CONSOLE=true

# MySQL (production)
# DB_URL=jdbc:mysql://localhost:3306/cricket_tournament?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password
# JPA_DIALECT=org.hibernate.dialect.MySQLDialect
# H2_CONSOLE=false

# ── JPA / Hibernate ──────────────────────────────────────────
# Options: create | create-drop | update | validate | none
# Use "update" for first boot; switch to "validate" once schema is stable.
DDL_AUTO=update

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Production example:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── JWT ──────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION — min 32 characters.
# Generate: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-in-production-min-32-chars
# Token lifetime in milliseconds (default: 24 h)
JWT_EXPIRATION_MS=86400000

# ── Auth Credentials ─────────────────────────────────────────
# Users are stored in the database with BCrypt-hashed passwords.
# On every startup, DataInitializer creates these users if they don't exist,
# or re-hashes and updates them if the password changed.
# To rotate a password: change the env var and restart — no manual DB edit needed.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Administrator

SCORER_USERNAME=scorer
SCORER_PASSWORD=change-this-scorer-password
SCORER_NAME=Match Scorer

# ── Spring Profile ───────────────────────────────────────────
# "dev"  — H2 in-memory, H2 console enabled
# "prod" — expects external DB (set DB_* above)
SPRING_PROFILES_ACTIVE=dev
