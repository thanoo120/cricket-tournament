# ============================================================
# Cricket Tournament — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local for local overrides (git-ignored).
# In production, set these in your hosting platform (Vercel, Netlify, etc.)
# ============================================================

# Backend API base URL.
# Leave UNSET in development — the CRA proxy in package.json forwards /api to localhost:8080.
# In production, set this to your deployed backend URL (no trailing slash).
# REACT_APP_API_URL=https://api.your-domain.com
